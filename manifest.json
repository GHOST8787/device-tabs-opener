{
  "manifest_version": 3,
  "name": "裝置分頁批次開啟器",
  "version": "2.1.0",
  "description": "一鍵批次開啟 iPhone/iPad 同步的分頁",
  "permissions": [
    "sessions",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "裝置分頁批次開啟器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
